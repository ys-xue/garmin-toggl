// Copy this file to source/Secrets.mc and fill in your values.
// source/Secrets.mc is gitignored — your secrets stay local.
module Secrets {
    // From https://track.toggl.com/profile (bottom of page).
    const TOGGL_TOKEN  = "YOUR_TOGGL_API_TOKEN_HERE";

    // From any Toggl URL after /workspaces/<id>/, or in workspace settings.
    const WORKSPACE_ID = "YOUR_WORKSPACE_ID_HERE";

    // Pre-computed HTTP Basic auth header. On macOS:
    //   echo -n "YOUR_TOGGL_API_TOKEN_HERE:api_token" | base64
    // Then prefix the result with "Basic " (note the trailing space).
    const AUTH_HEADER  = "Basic BASE64_OF_TOKEN_COLON_api_token";
}
